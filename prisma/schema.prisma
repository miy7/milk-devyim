generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum WorkPlanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  username         String            @unique
  passwordHash     String
  role             Role              @default(EMPLOYEE)
  employeeId       String?           @unique
  employee         Employee?         @relation("EmployeeAccount", fields: [employeeId], references: [id], onDelete: SetNull)
  createdWorkPlans WorkPlan[]        @relation("WorkPlanCreatedBy")
  createdFinances  EmployeeFinance[] @relation("FinanceCreatedBy")
  activities       ActivityLog[]     @relation("ActivityActor")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Employee {
  id          String              @id @default(cuid())
  fullName    String
  nickname    String?
  phone       String?
  position    String
  dailyRate   Decimal             @db.Decimal(10, 2)
  role        Role                @default(EMPLOYEE)
  status      EmployeeStatus      @default(ACTIVE)
  note        String?
  user        User?               @relation("EmployeeAccount")
  finances    EmployeeFinance[]
  assignments WorkPlanAssignment[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status, role])
}

model WorkPlan {
  id          String               @id @default(cuid())
  title       String
  description String
  date        DateTime
  startTime   String
  endTime     String
  status      WorkPlanStatus       @default(PENDING)
  note        String?
  location    String?
  createdById String?
  createdBy   User?                @relation("WorkPlanCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignments WorkPlanAssignment[]
  finances    EmployeeFinance[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([date, status])
}

model WorkPlanAssignment {
  id         String   @id @default(cuid())
  workPlanId String
  employeeId String
  workPlan   WorkPlan @relation(fields: [workPlanId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([workPlanId, employeeId])
  @@index([employeeId])
}

model EmployeeFinance {
  id             String        @id @default(cuid())
  employeeId     String
  workPlanId     String?
  createdById    String?
  date           DateTime
  workReference  String
  dailyWage      Decimal       @db.Decimal(10, 2)
  bonus          Decimal       @default(0) @db.Decimal(10, 2)
  deduction      Decimal       @default(0) @db.Decimal(10, 2)
  advancePayment Decimal       @default(0) @db.Decimal(10, 2)
  totalPayable   Decimal       @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(PENDING)
  note           String?
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  workPlan       WorkPlan?     @relation(fields: [workPlanId], references: [id], onDelete: SetNull)
  createdBy      User?         @relation("FinanceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([date, paymentStatus])
  @@index([employeeId, date])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String?
  action      String
  entityType  String
  entityId    String?
  description String
  metadata    Json?
  actor       User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([createdAt])
}
